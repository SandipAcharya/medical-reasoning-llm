# HuggingFace Token (Required for downloading models like LLaMA-3)
# Get one here: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Weights & Biases API Key (Optional, for training telemetry)
# Get one here: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here
